# poke-deck Steam Deck deploy config — copy to .env and fill in.
# `make deploy` reads these. .env is git-ignored.

# Connection (hostname works if your Deck is "steamdeck" on the LAN; else use its IP)
DECK_HOST=steamdeck
DECK_USER=deck
DECK_PORT=22

# Required for the sudo install steps (homebrew/plugins is root-owned).
# Set a password in SteamOS: Settings -> System, or `passwd` in Konsole.
# SSH keys (ssh-copy-id deck@steamdeck) avoid per-command prompts, but sudo still
# needs this password. Requires `sshpass` installed on this machine.
DECK_PASSWORD=your_deck_password_here

# Where Decky loads plugins from (rarely needs changing).
DECK_PLUGIN_DIR=/home/deck/homebrew/plugins/poke-deck

# Frontend debugging: enable "Allow Remote CEF Debugging" in Decky -> Developer,
# then open http://steamdeck:8081 (Chrome inspect or Playwright MCP).
CEF_DEBUG_PORT=8081

# 1 = inject the plugin.json "debug" flag on deploy so Decky auto-reloads the
# plugin (fast iteration). Set 0 for a clean, store-like deploy.
DEBUG=1
